import cloudinary.uploader
from rest_framework import viewsets, status, filters
from rest_framework.permissions import IsAuthenticated
from rest_framework.response import Response
from django_filters.rest_framework import DjangoFilterBackend
from .models import EvidenciaProyecto
from .serializers import EvidenciaProyectoSerializer

class EvidenciaProyectoViewSet(viewsets.ModelViewSet):
    """
    CRUD completo de evidencias.
    - GET    /api/evidencias/         → lista todas las evidencias del usuario
    - POST   /api/evidencias/         → crea una evidencia (sube archivo a Cloudinary)
    - GET    /api/evidencias/{id}/    → detalle de una evidencia
    - PUT    /api/evidencias/{id}/    → actualiza una evidencia
    - PATCH  /api/evidencias/{id}/    → actualización parcial
    - DELETE /api/evidencias/{id}/    → elimina una evidencia
    """
    serializer_class = EvidenciaProyectoSerializer
    permission_classes = [IsAuthenticated]

    filter_backends = [DjangoFilterBackend, filters.SearchFilter, filters.OrderingFilter]
    filterset_fields = ['categoria', 'proyecto']
    search_fields = ['titulo', 'proyecto', 'descripcion']
    ordering_fields = ['fecha_creacion', 'fecha_actualizacion', 'titulo']
    ordering = ['-fecha_creacion']

    def get_queryset(self):
        if getattr(self, 'swagger_fake_view', False):
            return EvidenciaProyecto.objects.none()
        return EvidenciaProyecto.objects.filter(autor=self.request.user)

    def create(self, request, *args, **kwargs):
        """
        Sobrescribe create para:
        1. Interceptar el archivo del multipart/form-data
        2. Subirlo a Cloudinary
        3. Guardar la URL pública en el registro
        """
        serializer = self.get_serializer(data=request.data)
        serializer.is_valid(raise_exception=True)

        archivo = serializer.validated_data.pop('archivo', None)
        archivo_url = ''
        archivo_nombre = ''
        archivo_tipo = ''
        archivo_tamano = 0

        if archivo:
            try:
                # Determinar tipo de recurso para Cloudinary
                content_type = getattr(archivo, 'content_type', '')
                resource_type = 'raw' if 'pdf' in content_type else 'image'

                resultado = cloudinary.uploader.upload(
                    archivo,
                    folder='evidencias_proyectos',
                    resource_type=resource_type,
                )

                archivo_url = resultado.get('secure_url', '')
                archivo_nombre = archivo.name
                archivo_tipo = archivo.name.rsplit('.', 1)[-1].lower() if '.' in archivo.name else ''
                archivo_tamano = archivo.size

            except Exception as e:
                return Response(
                    {'error': f'Error al subir el archivo a Cloudinary: {str(e)}'},
                    status=status.HTTP_500_INTERNAL_SERVER_ERROR
                )

        # Guardar la evidencia con los datos del archivo
        evidencia = serializer.save(
            autor=request.user,
            archivo_url=archivo_url,
            archivo_nombre_original=archivo_nombre,
            archivo_tipo=archivo_tipo,
            archivo_tamano=archivo_tamano,
        )

        return Response(
            self.get_serializer(evidencia).data,
            status=status.HTTP_201_CREATED
        )

    def perform_update(self, serializer):
        serializer.save(autor=self.request.user)
